# =============================================================================
# FastAPI Google Auth Template - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate secret keys:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# -----------------------------------------------------------------------------
# App Branding
# -----------------------------------------------------------------------------
PROJECT_NAME=My App
PROJECT_TAGLINE=Built with FastAPI + Google OAuth

# -----------------------------------------------------------------------------
# Google OAuth2 Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# For local development:
APP_BASE_URL=http://127.0.0.1:8000
# For production (uncomment and set your domain):
# APP_BASE_URL=https://yourdomain.com

# Redirect URI after Google authentication
# This must match "Authorized redirect URIs" in GCP Console
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# -----------------------------------------------------------------------------
# Security Keys (Required)
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-key

# -----------------------------------------------------------------------------
# JWT Settings
# -----------------------------------------------------------------------------
# Access token expiration in minutes
JWT_EXPIRE_MINUTES=60
# Refresh token expiration in days
JWT_REFRESH_DAYS=7
